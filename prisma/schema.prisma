// Prisma schema do app Grana

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String?  @unique
  passwordHash  String?  // bcrypt-like hash; null pra contas demo/anonimas
  name          String?
  profissao     String?

  regime        String?
  meiAtividade  String?
  meiInicio     DateTime?
  simplesAnexo  String?
  simplesInicio DateTime?

  contadorNome     String?
  contadorWhatsapp String?
  contadorEmail    String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions Transaction[]
  uploads      Upload[]
  dasPayments  DASPayment[]
  indicacoes   Indicacao[]
  avaliacoes   Avaliacao[]
  passwordResetTokens PasswordResetToken[]
  reminderLogs ReminderLog[]
  budgets      Budget[]

  // Preferencias de lembrete. Default: tudo ligado.
  reminderDasEnabled       Boolean @default(true)
  reminderInactivityEnabled Boolean @default(true)

  /// Percentual sugerido pra separar do faturamento como reserva de imposto.
  /// null = usar o default da lib (8% pra Simples, fixo pra MEI).
  taxReserveAutoPercent Int?

  taxReserves TaxReserve[]
  clientes    Cliente[]
  recibos     Recibo[]
  dasnRecibos DasnRecibo[]
  relatoriosMensais RelatorioMensal[]
}

/// Reserva de impostos: a usuaria separa um pedaco do faturamento todo mes
/// pra nao ser pega de surpresa no DAS. A gente registra cada contribuicao
/// (manual ou sugerida pelo "auto").
///
/// Decisoes:
///  - Cada deposito eh um row, agregado por (year, month) na consulta. Da
///    pra ver o historico e remover entradas individuais.
///  - amount em positivo (valor que ENTROU na reserva).
///  - auto=true marca depositos criados pelo botao "reservar agora" baseado
///    em receita do mes; auto=false eh entrada manual.
model TaxReserve {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  year      Int
  month     Int      // 1-12
  amount    Float
  note      String?
  auto      Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, year, month])
}

/// Limite mensal de gastos por categoria. Usuaria define quanto pretende
/// gastar com "alimentacao" / "transporte_pessoal" / etc num mes; a gente
/// calcula o progresso somando todas as transacoes (despesa + pessoal) da
/// categoria dentro do mes corrente.
///
/// Decisoes:
///  - Um unico registro por (userId, category). O limite eh "do mes
///    corrente" e nao precisamos armazenar historico por mes pra V1.
///  - alertThreshold em % (0-100): quando atinge, marcamos visualmente
///    como "alerta". Default 80.
///  - Categoria eh string livre (nao FK) pra acompanhar as categorias
///    existentes em Transaction.category.
model Budget {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  category        String
  monthlyLimit    Float
  alertThreshold  Int      @default(80)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, category])
  @@index([userId])
}

/// Registro de lembretes ja enviados, pra nao spammar a usuaria.
/// Cada combinacao (userId + kind + reference) so dispara uma vez.
/// reference e uma string canonizada — ex: "das:2026-07" ou "inactivity:2026-W25".
model ReminderLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  kind      String   // "das_due" | "inactivity_week" | ...
  reference String   // chave canonica do periodo, garante idempotencia
  sentAt    DateTime @default(now())

  @@unique([userId, kind, reference])
  @@index([userId])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique // sha256 do token cru, hex; nunca armazenamos o token em texto
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())
  requestIp  String?
  userAgent  String?

  @@index([userId])
  @@index([expiresAt])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  date            DateTime
  amount          Float
  description     String
  contraparte     String?
  contraparteDoc  String?  // CPF/CNPJ apenas digitos, quando disponivel no extrato

  type            String
  category        String
  isDeductible    Boolean  @default(false)
  isPersonal      Boolean  @default(false)
  isRecurring     Boolean  @default(false)

  source          String
  uploadId        String?
  upload          Upload?  @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  aiSuggested     Boolean  @default(false)
  userConfirmed   Boolean  @default(false)
  notes           String?
  attachmentUrl   String?
  notaNumero      String?  // numero da NF emitida pra esta receita

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, date])
  @@index([userId, type])
  @@index([userId, contraparteDoc])
}

model Upload {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName     String
  fileSize     Int
  bankDetected String?
  status       String
  errorMsg     String?
  rawText      String?
  txCount      Int      @default(0)

  transactions Transaction[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DASPayment {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  month     Int
  year      Int
  value     Float
  dueDate   DateTime
  paidAt    DateTime?
  proofUrl  String?
  notes     String?

  regime    String?
  rbt12     Float?
  aliquota  Float?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, year, month])
  @@index([userId, dueDate])
}

model ContadorParceiro {
  id            String   @id @default(cuid())
  nome          String
  foto          String?
  especialidade String?
  cidade        String?
  whatsapp      String?
  email         String?
  preco         String?
  ativo         Boolean  @default(true)
  ordem         Int      @default(0)
  bio           String?  // pequena descricao

  // Cache calculado da media e contagem (atualizado quando avaliacao e criada)
  notaMedia     Float?
  notaCount     Int      @default(0)

  indicacoes    Indicacao[]
  avaliacoes    Avaliacao[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Indicacao {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parceiroId  String
  parceiro    ContadorParceiro @relation(fields: [parceiroId], references: [id], onDelete: Cascade)

  status      String           @default("enviada") // enviada | contato | fechou | desistiu
  notes       String?

  // Quando foi convertida em avaliacao (pra nao perguntar 2 vezes)
  avaliadaEm  DateTime?

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
  @@index([parceiroId])
  @@index([userId, avaliadaEm])
}

model Avaliacao {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  parceiroId  String
  parceiro    ContadorParceiro @relation(fields: [parceiroId], references: [id], onDelete: Cascade)

  nota        Int              // 1 a 5
  comentario  String?          // ate 200 chars
  oculta      Boolean          @default(false) // pra moderacao

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, parceiroId])
  @@index([parceiroId])
}

// Telemetria por upload: quantas txs cada camada do classificador resolveu,
// quantas chamadas de IA aconteceram, e quantas o usuario corrigiu depois.
// Usado pra ajustar threshold da IA e melhorar heuristica com base em dados reais.
model ClassificationMetric {
  id            String   @id @default(cuid())
  userId        String
  uploadId      String?

  totalTxs      Int
  fromHistory   Int      // camada 1: match historico/recorrencia/documento
  fromHeuristic Int      // camada 2: regras de palavra-chave
  fromAI        Int      // camada 3: Claude

  aiCallsCount  Int      @default(0) // quantas chamadas (batches) foram pra IA
  aiTxsCount    Int      @default(0) // total de txs enviadas pra IA

  correctedTxs  Int      @default(0) // quantas o usuario alterou depois
  correctedAt   DateTime?

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([uploadId])
}

// Memoria de correcao negativa: cada vez que o usuario altera uma classificacao
// que veio da IA, gravamos o par (sugestao IA -> correcao usuario). Esses pares
// alimentam o prompt da IA em uploads futuros, evitando repetir o mesmo erro.
model ClassificationCorrection {
  id              String   @id @default(cuid())
  userId          String

  // contexto da transacao (snapshot na hora da correcao)
  description     String
  contraparte     String?
  contraparteDoc  String?
  amount          Float

  // o que a IA havia sugerido
  aiType          String
  aiCategory      String
  aiIsDeductible  Boolean
  aiIsPersonal    Boolean

  // o que o usuario corrigiu pra
  userType        String
  userCategory    String
  userIsDeductible Boolean
  userIsPersonal  Boolean

  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, contraparteDoc])
}

/// Clientes recorrentes da MEI. Salvar uma vez evita redigitar CPF/nome a cada
/// recibo ou NF.
///
/// Convencao:
///  - `doc` guarda CPF/CNPJ apenas com digitos pra busca rapida.
///  - `whatsapp` em formato livre, mas a UI tenta normalizar pra E.164 quando
///    monta o link wa.me.
///  - Indice unique (userId, doc) impede duplicar o mesmo cliente, MAS doc
///    e opcional (clientes informais entram so com nome).
model Cliente {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  nome      String
  doc       String?  // CPF/CNPJ apenas digitos
  whatsapp  String?
  email     String?
  endereco  String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recibos   Recibo[]

  @@index([userId, nome])
  @@index([userId, doc])
}

/// Recibo de pagamento (NAO substitui nota fiscal).
/// Cada recibo gerado pelo app fica salvo aqui pra historico e pra reimpressao
/// futura. O numero e sequencial por user (1, 2, 3, ...) — nao tem validade
/// fiscal, e so pra organizacao.
model Recibo {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  clienteId String?
  cliente   Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  numero    Int      // sequencial por user
  data      DateTime
  valor     Float
  descricao String

  // Snapshot dos dados na hora da emissao, pra recibo continuar igual mesmo
  // se o cliente for editado/deletado depois.
  clienteNome     String
  clienteDoc      String?
  clienteContato  String?  // whatsapp ou email usado no envio

  createdAt DateTime @default(now())

  @@index([userId, data])
  @@unique([userId, numero])
}

/// Historico de DASN-SIMEI entregue por ano. O MEI marca como entregue
/// apos enviar no portal da Receita e (opcionalmente) anexa o PDF do
/// recibo. Util pra provar a entrega depois — Receita mantem por anos
/// mas e mais facil ter copia local.
model DasnRecibo {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  year            Int      // ano-base declarado
  deliveredAt     DateTime // quando declarou no portal
  valorDeclarado  Float    // receita bruta total que foi declarada
  receitaComercio Float    @default(0)
  receitaServicos Float    @default(0)

  // Path no Supabase Storage. URL assinada e gerada na hora pra exibir.
  pdfPath         String?

  createdAt       DateTime @default(now())

  @@unique([userId, year])
  @@index([userId])
}

/// Relatorio mensal de receitas (obrigacao legal do MEI). Gerado
/// automaticamente todo dia 5 pelo cron, ou sob demanda pela usuaria.
/// Fica salvo no Storage pra nao precisar regerar e pra manter copia.
///
/// Snapshot dos numeros principais ficam no banco — assim a lista pode
/// mostrar receita/despesa/lucro sem precisar abrir o PDF.
model RelatorioMensal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  year        Int
  month       Int      // 1-12

  // Snapshots
  receita     Float    @default(0)
  despesas    Float    @default(0)
  lucro       Float    @default(0)
  txCount     Int      @default(0)

  // Path no Supabase Storage. Se null, regerou e nao subiu (ou storage off).
  pdfPath     String?

  // Origem da geracao
  geradoAuto  Boolean  @default(false)
  geradoEm    DateTime @default(now())

  @@unique([userId, year, month])
  @@index([userId, year, month])
}
