# =====================================================================
# Grana — variaveis de ambiente
# =====================================================================
# Local: copie pra .env e preencha. NUNCA comite o .env.
# Producao (Netlify): configure essas mesmas chaves no painel
# Site settings -> Environment variables.
# =====================================================================

# ----- Banco de dados (Supabase / Postgres) --------------------------
# DATABASE_URL: usa o pooler (porta 6543) — eh o que o app usa em runtime.
#   pgbouncer=true e connection_limit=1 sao recomendados pelo Prisma
#   pra evitar prepared statements presos no pooler.
# DIRECT_URL  : usa a conexao direta (porta 5432) — usada por
#   `prisma migrate` (DDL nao funciona via pooler em modo Transaction).
DATABASE_URL="postgresql://postgres.PROJETO:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:SENHA@db.PROJETO.supabase.co:5432/postgres"

# ----- IA (categorizacao de transacoes) ------------------------------
ANTHROPIC_API_KEY=""

# ----- DAS (geracao de boleto) ---------------------------------------
DAS_PROVIDER_API_KEY=""

# ----- Painel admin --------------------------------------------------
# Voce, dono do app, usa essa senha pra gerenciar parceiros e ver alertas.
# Em producao: troque por algo forte (>=20 chars, gerador aleatorio).
ADMIN_PASSWORD="troque-essa-senha"

# ----- Modo ----------------------------------------------------------
# Em producao o Netlify injeta NODE_ENV=production sozinho.
NODE_ENV="development"

# ----- Demo / showcase ----------------------------------------------
# Quando setado, qualquer visitante sem cookie cai automaticamente neste user
# (em vez de criar um vazio). Util pra demonstrar o app populado.
# Deixe vazio em producao real pra cada visitante ter conta propria.
DEMO_USER_ID=""
